{
  "module_name": "RotateVectorByMinusYaw",
  "traits_type": "RotateVectorByMinusYawTraits",
  "description": "RotateVectorByMinusYaw Traits 级单元测试用例",
  "test_cases": [
    {
      "id": "TC1_identity",
      "input": {
        "vxGlobal": 1,
        "vyGlobal": 0,
        "yaw": 0
      },
      "expected_output": {
        "vxEgo": 1,
        "vyEgo": 0
      }
    },
    {
      "id": "TC2_quarter_turn",
      "input": {
        "vxGlobal": 0,
        "vyGlobal": 1,
        "yaw": 1.5708
      },
      "expected_output": {
        "vxEgo": 1,
        "vyEgo": 0
      },
      "tolerance": 0.001
    },
    {
      "id": "TC3_minus_quarter",
      "input": {
        "vxGlobal": 1,
        "vyGlobal": 0,
        "yaw": 1.5708
      },
      "expected_output": {
        "vxEgo": 0,
        "vyEgo": -1
      },
      "tolerance": 0.001
    }
  ]
}